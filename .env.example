# Local: copy to .env.local (gitignored). Vercel: Project → Settings → Environment Variables.
#
# This app is Vite — prefer VITE_* names. NEXT_PUBLIC_* also works (see vite.config.js envPrefix).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Legacy JWT anon key still supported if you have not migrated to publishable keys yet:
# VITE_SUPABASE_ANON_KEY=eyJ...

# Optional: same values with Next-style names (e.g. if you paste from Supabase dashboard):
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Stripe (browser publishable key only — never the secret key here)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...

# Hostinger Ecommerce API (override when you migrate commerce)
VITE_ECOMMERCE_API_URL=https://api-ecommerce.hostinger.com
VITE_ECOMMERCE_STORE_ID=store_...

# Marketing images: defaults to Hostinger Horizons CDN path; set to your CDN or Supabase public URL when you migrate assets
# VITE_MEDIA_CDN_BASE=https://your-cdn.example.com/your-prefix

# --- Secret key (sb_secret_...) — NEVER add here with VITE_ or NEXT_PUBLIC_ prefix ---
# Those prefixes expose values to the browser bundle. Secret keys bypass RLS: servers only
# (Supabase Edge Functions with secrets, your own Node API, CI scripts). This SPA only needs
# the publishable key above. If you add a backend later, use a non-VITE name and server-only env.

# Edge Functions (set in Supabase Dashboard → Edge Functions → Secrets, not in Vercel):
# STRIPE_SECRET_KEY=sk_...
# SUPABASE_SERVICE_ROLE_KEY=...  (only for manage-api-keys function)
